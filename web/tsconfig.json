{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@pronostico-apps/ui": ["./vendor/pronostico-apps/packages/ui/index.ts"],
      "@pronostico-apps/interfaces": ["./vendor/pronostico-apps/packages/interfaces/index.ts"],
      "@pronostico-apps/prediction-market": ["./vendor/pronostico-apps/packages/prediction-market/index.ts"],
      "@pronostico-apps/common": ["./vendor/pronostico-apps/packages/common/index.ts"],
      "@pronostico-apps/theme-css": ["./vendor/pronostico-apps/packages/theme-css"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", "vendor"]
}
