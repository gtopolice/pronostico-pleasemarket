# Chiwiwis agent worker + BFF
CHIWIWIS_X_HANDLE=Chiwiwis
CHIWIWIS_WEB_URL=https://chiwiwis.anyone.market
ANYONE_WEB_BASE=https://anyone.market
API_URL=https://prod.api.pronostico.market/api
API_TOKEN=
AGENT_SERVICE_SECRET=

# X API v2
X_API_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_WEBHOOK_ENV=development

# LLM
OPENAI_API_KEY=
CHIWIWIS_LLM_MODEL=gpt-4o-mini

# Agent behavior
AGENT_DEPLOY_ENABLED=0
CHIWIWIS_DRY_RUN=1
CHIWIWIS_DEPLOY_ALLOWLIST=
CHIWIWIS_RESOLVE_SLA_HOURS=48
CHIWIWIS_DEFAULT_CREATOR_FEE_BPS=25
CHIWIWIS_DEFAULT_IMAGE_URL=https://anyone.market/og-image.png

# Claims poster
CHIWIWIS_CLAIM_POST_ENABLED=1
CHIWIWIS_CLAIM_POST_MIN_USDC=50
CHIWIWIS_CLAIM_POST_ONLY_CHIWIWIS_MARKETS=1
CHIWIWIS_CLAIM_POST_MAX_PER_HOUR=10
CLAIMS_POLL_INTERVAL_SECONDS=30

# Postgres (reputation, dedupe, audit)
DATABASE_URL=postgresql://chiwiwis:chiwiwis@localhost:5432/chiwiwis

# Rate limits
CHIWIWIS_RATE_LIMIT_PER_USER_DAY=5
CHIWIWIS_GLOBAL_KILL_SWITCH=0

# Web (Next.js) — see web/.env.local.example
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_CLIENT_ID=
NEXT_PUBLIC_CHIWIWIS_API_BASE=http://localhost:8080
