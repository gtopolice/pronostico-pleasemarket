# Please.market agent worker + BFF
PLEASE_X_HANDLE=PleaseMarketBot
PLEASE_WEB_URL=https://please.market
ANYONE_WEB_BASE=https://anyone.market
API_URL=https://prod.api.pronostico.market/api
API_TOKEN=
AGENT_SERVICE_SECRET=
LINK_COMPLETE_SECRET=

# X API v2
X_API_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BOT_USER_ID=
MENTIONS_POLL_ENABLED=1
MENTIONS_POLL_INTERVAL_SECONDS=30
X_WEBHOOK_ENV=development

# LLM
OPENAI_API_KEY=
PLEASE_LLM_MODEL=gpt-4o-mini

# Agent behavior
AGENT_DEPLOY_ENABLED=0
PLEASE_DRY_RUN=1
PLEASE_DEPLOY_ALLOWLIST=
PLEASE_RESOLVE_SLA_HOURS=48
PLEASE_DEFAULT_CREATOR_FEE_BPS=25
PLEASE_DEFAULT_IMAGE_URL=https://please.market/assets/please_logo.png

# Claims poster
PLEASE_CLAIM_POST_ENABLED=1
PLEASE_CLAIM_POST_MIN_USDC=50
PLEASE_CLAIM_POST_ONLY_PLEASE_MARKETS=1
PLEASE_CLAIM_POST_MAX_PER_HOUR=10
CLAIMS_POLL_INTERVAL_SECONDS=30

# Postgres (reputation, dedupe, audit)
DATABASE_URL=postgresql://please:please@localhost:5432/please

# Rate limits
PLEASE_RATE_LIMIT_PER_USER_DAY=5
PLEASE_GLOBAL_KILL_SWITCH=0

# Web (Next.js) — see web/.env.local.example
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_CLIENT_ID=
NEXT_PUBLIC_PLEASE_API_BASE=http://localhost:8080
LINK_COMPLETE_SECRET=
